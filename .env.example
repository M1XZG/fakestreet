# Copy this file to .env and adjust values as needed.

# Path to the SQLite database file. Use /app/data/trading_game.db in Docker so user data is stored in the named volume.
TRADING_GAME_DB=trading_game.db

# Host interface for Uvicorn to bind.
TRADING_GAME_HOST=0.0.0.0

# Port for the FastAPI server.
TRADING_GAME_PORT=8000

# Starting cash balance for new accounts.
TRADING_GAME_STARTING_CASH=100000

# Market data cache lifetime in seconds.
TRADING_GAME_CACHE_TTL=60
